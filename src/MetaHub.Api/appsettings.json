{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "MetaHub": "Host=localhost;Port=5432;Database=metahub;Username=metahub;Password=metahub"
  },
  "MetaHub": {
    "AutoMigrate": true
  },
  "AnimeIngest": {
    "ManamiUrl": "https://raw.githubusercontent.com/manami-project/anime-offline-database/master/anime-offline-database-minified.json",
    "FribbUrl": "https://raw.githubusercontent.com/Fribb/anime-lists/master/anime-lists-full.json",
    "UserAgent": "MetaHub/0.1 (+https://github.com/kuschel-code/jdb)"
  },
  "AniDb": {
    "Enabled": false,
    "Host": "api.anidb.net",
    "Port": 9000,
    "ClientName": "metahub",
    "ClientVersion": 1,
    "Username": "",
    "Password": "",
    "MinRequestIntervalSeconds": 4,
    "ReceiveTimeoutSeconds": 20
  },
  "Enrichment": {
    "TtlFinishedDays": 30,
    "TtlOngoingDays": 1,
    "WriteMode": "FillMissingOnly",
    "UserAgent": "MetaHub/0.1 (+https://github.com/kuschel-code/jdb)",
    "TmdbApiKey": "",
    "GoogleBooksApiKey": ""
  },
  "Scheduler": {
    "Enabled": false,
    "EnrichmentEnabled": true,
    "EnrichmentIntervalMinutes": 360,
    "EnrichmentBatchSize": 100,
    "EnrichmentDelayMs": 1000,
    "EnrichmentOnlyMissing": true,
    "IngestEnabled": false,
    "IngestIntervalHours": 168,
    "ScanEnabled": false,
    "ScanIntervalMinutes": 60,
    "ScanMaxFilesPerRun": 200,
    "AnimeLibraryPaths": [],
    "VideoExtensions": [ ".mkv", ".mp4", ".avi", ".ogm", ".wmv", ".mov" ]
  }
}
